# Database configuration
# Use SQLite for development (default)
DATABASE_URL=sqlite:///smartbudget.db
# Use PostgreSQL for production (example)
# DATABASE_URL=postgresql://user:password@localhost:5432/smartbudget

# OpenAI API Key for Budget Coach AI and Spending Anomaly Detection
# If left blank, the system will use a local rules-based simulation.
OPENAI_API_KEY=

# Security configurations
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=some-aes-key-for-credentials-optional

# Email notifications (optional — simulated in terminal if left blank)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user@example.com
EMAIL_SMTP_PASSWORD=your-app-password
# Set to true for SMTP_SSL (e.g. port 465)
EMAIL_SMTP_USE_SSL=false
